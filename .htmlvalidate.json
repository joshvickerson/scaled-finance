{
	"extends": ["html-validate:recommended"],
	"rules": {
		"doctype-style": 0,
		"no-dup-class": 0,
		"element-permitted-content": 1,
		"attribute-allowed-values": 1,
		"attribute-boolean-style": 0,
		"attribute-empty-style": 1,
		"no-dup-id": 1,
		"no-trailing-whitespace": 0,
		"no-raw-characters": 0,
		"attribute-allowed-values": 1,
		"long-title": 1,
		"wcag/h30": 0,
		"svg-focusable": 0
	}
}
